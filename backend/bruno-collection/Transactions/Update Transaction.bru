  token: {{token}}
}

body:json {
  {
    "type": "expense",
    "amount": 175.00,
    "description": "Compra no supermercado - atualizada",
    "date": "2026-03-09T10:00:00.000Z",
    "category_id": 1
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000/api
}
