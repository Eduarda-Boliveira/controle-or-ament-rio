meta {
  name: Create Transaction
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/transactions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "type": "expense",
    "amount": 150.50,
    "description": "Compra no supermercado",
    "date": "2026-03-09T10:00:00.000Z",
    "category_id": 1
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000/api
}
